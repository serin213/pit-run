{
  "expo": {
    "name": "pit-run",
    "slug": "pit-run",
    "version": "1.0.0",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#17171C"
    },
    "scheme": "pitrun",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.pit-run",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSLocationAlwaysAndWhenInUseUsageDescription": "달리는 동안 화면이 꺼져도 정확한 거리를 측정합니다.",
        "NSLocationAlwaysUsageDescription": "화면이 꺼진 상태에서도 러닝 세션을 추적합니다.",
        "NSLocationWhenInUseUsageDescription": "달리는 동안 정확한 거리를 측정합니다.",
        "UIBackgroundModes": ["location"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#17171C"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.pitrun",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-font",
      "expo-asset",
      "expo-apple-authentication",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "달리는 동안 화면이 꺼져도 정확한 거리를 측정합니다.",
          "locationAlwaysPermission": "화면이 꺼진 상태에서도 러닝 세션을 추적합니다.",
          "locationWhenInUsePermission": "달리는 동안 정확한 거리를 측정합니다.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ]
    ]
  }
}
